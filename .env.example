# ========================================
# Wiki 百科网站 - 环境变量配置
# ========================================
# 复制此文件为 .env 并修改相应配置

# ----------------------------------------
# 服务器配置
# ----------------------------------------

# 服务器端口（默认：3001）
PORT=3001

# Session 加密密钥（生产环境必须修改）
SESSION_SECRET=wiki-encyclopedia-change-this-in-production

# CORS 允许的来源（留空允许所有，生产环境建议指定）
CORS_ORIGIN=

# ----------------------------------------
# 数据库配置
# ----------------------------------------

# 数据库 API 地址（可选，默认使用内置配置）
DATABASE_API_URL=http://localhost:3000/api

# 数据库 Token（如果需要）
DATABASE_TOKEN=

# ----------------------------------------
# 文件上传配置
# ----------------------------------------

# 允许的文件类型（逗号分隔）
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp

# 文件大小限制（字节，默认 5MB = 5242880）
MAX_FILE_SIZE=5242880

# 上传文件存储目录
UPLOAD_DIR=./public/uploads

# ----------------------------------------
# 会话配置
# ----------------------------------------

# 会话有效期（毫秒，默认 24 小时）
SESSION_MAX_AGE=86400000

# 是否强制 HTTPS（生产环境设为 true）
FORCE_HTTPS=false

# ----------------------------------------
# 功能开关
# ----------------------------------------

# 是否允许用户注册（设为 false 可关闭注册）
ALLOW_REGISTRATION=true

# 是否启用游客浏览（设为 false 可要求登录才能浏览）
ALLOW_GUEST_BROWSE=true

# ----------------------------------------
# 日志配置
# ----------------------------------------

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# 是否启用详细错误信息（生产环境设为 false）
SHOW_ERROR_DETAILS=true
